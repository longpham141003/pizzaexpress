@model LoginViewModel
@{
    Layout = "_LoginLayout";
    ViewData["Title"] = "Đăng nhập";
}

<div class="login-card">
    <div class="login-logo">
        <div class="sidebar-brand-icon" style="width:48px;height:48px;margin:0 auto">
            <span class="material-symbols-outlined" style="font-size:26px">local_pizza</span>
        </div>
        <h1>Pizza Express</h1>
        <p>Đăng nhập vào trang quản trị</p>
    </div>

    <form method="post" asp-action="Login" asp-controller="Account" asp-area="Admin">
        <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

        <div asp-validation-summary="All" class="alert alert-danger" style="@(ViewData.ModelState.IsValid ? "display:none" : "")"></div>

        <div class="form-group">
            <label asp-for="Email">Email</label>
            <input asp-for="Email" class="form-control" placeholder="admin@pizzaexpress.vn" autofocus />
            <span asp-validation-for="Email" class="field-validation-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="Password">Mật khẩu</label>
            <input asp-for="Password" class="form-control" placeholder="••••••••" />
            <span asp-validation-for="Password" class="field-validation-error"></span>
        </div>

        <div class="form-group">
            <label class="form-check">
                <input asp-for="RememberMe" type="checkbox" />
                <span class="text-sm">Ghi nhớ đăng nhập</span>
            </label>
        </div>

        <button type="submit" class="btn btn-primary btn-lg w-100" style="justify-content:center">
            <span class="material-symbols-outlined">login</span> Đăng nhập
        </button>
    </form>
</div>
