@model SiteSetting
@{ ViewData["Title"] = "Cài đặt hệ thống"; }

<div class="page-header"><h2>Cài đặt hệ thống</h2></div>

<form method="post" asp-action="Index" enctype="multipart/form-data">
<div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem">

    <!-- Branding -->
    <div class="card">
        <div class="card-header"><h3>🏢 Thương hiệu</h3></div>
        <div class="card-body">
            <div class="form-group"><label asp-for="SiteName">Tên website</label><input asp-for="SiteName" class="form-control" /></div>
            <div class="form-group"><label asp-for="Slogan">Slogan</label><input asp-for="Slogan" class="form-control" /></div>
            <div class="form-group"><label>Logo</label>
                @if(!string.IsNullOrEmpty(Model.LogoPath)){<img id="logoPreview" src="@(Model.LogoPath.StartsWith("/") ? Model.LogoPath : "/" + Model.LogoPath)" class="img-preview" style="display:block;margin-bottom:0.5rem;max-height:60px" />}
                else {<img id="logoPreview" class="img-preview" style="display:none;margin-bottom:0.5rem;max-height:60px" />}
                <input type="file" name="logoFile" accept="image/*" class="form-control" onchange="previewImage(this,'logoPreview')" /></div>
            <div class="form-group"><label>Favicon</label>
                @if(!string.IsNullOrEmpty(Model.FaviconPath)){<img id="faviconPreview" src="@(Model.FaviconPath.StartsWith("/") ? Model.FaviconPath : "/" + Model.FaviconPath)" class="img-preview" style="display:block;margin-bottom:0.5rem;max-height:32px" />}
                else {<img id="faviconPreview" class="img-preview" style="display:none;margin-bottom:0.5rem;max-height:32px" />}
                <input type="file" name="faviconFile" accept="image/*" class="form-control" onchange="previewImage(this,'faviconPreview')" /></div>
        </div>
    </div>

    <!-- Company Info -->
    <div class="card">
        <div class="card-header"><h3>📋 Thông tin công ty</h3></div>
        <div class="card-body">
            <div class="form-group"><label asp-for="CompanyName">Tên công ty</label><input asp-for="CompanyName" class="form-control" /></div>
            <div class="form-group"><label asp-for="CompanyAddress">Địa chỉ</label><input asp-for="CompanyAddress" class="form-control" /></div>
            <div class="form-group"><label asp-for="BusinessRegNumber">Số ĐKKD</label><input asp-for="BusinessRegNumber" class="form-control" /></div>
        </div>
    </div>

    <!-- Contact -->
    <div class="card">
        <div class="card-header"><h3>📞 Liên hệ</h3></div>
        <div class="card-body">
            <div class="form-group"><label asp-for="Hotline">Hotline (24/7)</label><input asp-for="Hotline" class="form-control" /></div>
            <div class="form-group"><label asp-for="FeedbackPhone">Số phản ánh dịch vụ</label><input asp-for="FeedbackPhone" class="form-control" /></div>
            <div class="form-group"><label asp-for="Email">Email</label><input asp-for="Email" class="form-control" type="email" /></div>
        </div>
    </div>

    <!-- Social Media -->
    <div class="card">
        <div class="card-header"><h3>🌐 Mạng xã hội</h3></div>
        <div class="card-body">
            <div class="form-group"><label asp-for="FacebookUrl">Facebook URL</label><input asp-for="FacebookUrl" class="form-control" /></div>
            <div class="form-group"><label asp-for="ZaloUrl">Zalo URL</label><input asp-for="ZaloUrl" class="form-control" /></div>
            <div class="form-group"><label asp-for="MessengerUrl">Messenger URL</label><input asp-for="MessengerUrl" class="form-control" /></div>
        </div>
    </div>

    <!-- SEO -->
    <div class="card">
        <div class="card-header"><h3>🔍 SEO & Analytics</h3></div>
        <div class="card-body">
            <div class="form-group"><label asp-for="SeoTitle">Meta Title mặc định</label><input asp-for="SeoTitle" class="form-control" /></div>
            <div class="form-group"><label asp-for="SeoDescription">Meta Description mặc định</label><textarea asp-for="SeoDescription" class="form-control" rows="2"></textarea></div>
            <div class="form-group"><label asp-for="GoogleAnalyticsId">Google Analytics ID</label><input asp-for="GoogleAnalyticsId" class="form-control" placeholder="UA-XXXXXXXXX-X hoặc G-XXXXXXXXXX" /></div>
            <div class="form-group"><label asp-for="GtmId">Google Tag Manager ID</label><input asp-for="GtmId" class="form-control" placeholder="GTM-XXXXXXX" /></div>
            <div class="form-group"><label asp-for="GoogleAdsId">Google Ads ID</label><input asp-for="GoogleAdsId" class="form-control" /></div>
            <div class="form-group"><label asp-for="FacebookPixelId">Facebook Pixel ID</label><input asp-for="FacebookPixelId" class="form-control" placeholder="335360117045551" /></div>
        </div>
    </div>

    <!-- Appearance -->
    <div class="card">
        <div class="card-header"><h3>🎨 Giao diện & Chính sách</h3></div>
        <div class="card-body">
            <div class="form-row">
                <div class="form-group"><label asp-for="PrimaryColor">Màu chính</label><input asp-for="PrimaryColor" type="color" class="form-control" style="height:40px" /></div>
                <div class="form-group"><label asp-for="SecondaryColor">Màu phụ</label><input asp-for="SecondaryColor" type="color" class="form-control" style="height:40px" /></div>
            </div>
            <div class="form-group"><label asp-for="PrivacyPolicyUrl">URL Chính sách bảo mật</label><input asp-for="PrivacyPolicyUrl" class="form-control" /></div>
            <div class="form-group"><label asp-for="ReturnPolicyUrl">URL Chính sách đổi trả</label><input asp-for="ReturnPolicyUrl" class="form-control" /></div>
            <div class="form-group"><label asp-for="PaymentPolicyUrl">URL Chính sách thanh toán</label><input asp-for="PaymentPolicyUrl" class="form-control" /></div>
        </div>
    </div>
</div>

<div class="mt-3">
    <button type="submit" class="btn btn-primary btn-lg"><span class="material-symbols-outlined">save</span> Lưu tất cả cài đặt</button>
</div>
</form>
