@model List<Product>
@{ ViewData["Title"] = "Quản lý Sản phẩm"; var cats = (List<Category>)ViewBag.Categories; }

<div class="page-header">
    <h2>Sản phẩm (@(ViewBag.TotalItems ?? Model.Count))</h2>
    <a href="/admin/products/create" class="btn btn-primary"><span class="material-symbols-outlined">add</span> Thêm sản phẩm</a>
</div>

<!-- Filter -->
<div class="card mb-3">
    <div class="card-body" style="padding:0.75rem 1.25rem">
        <form method="get" class="d-flex gap-3 align-center" style="flex-wrap:wrap">
            <select name="categoryId" class="form-control" style="width:auto;min-width:180px" onchange="this.form.submit()">
                <option value="">Tất cả danh mục</option>
                @foreach (var c in cats)
                {
                    <option value="@c.Id" selected="@(ViewBag.SelectedCategory != null && (int)ViewBag.SelectedCategory == c.Id)">@c.Name</option>
                }
            </select>
            <input name="q" value="@ViewBag.Search" class="form-control" style="width:auto;min-width:220px" placeholder="Tìm theo tên..." />
            <button type="submit" class="btn btn-secondary"><span class="material-symbols-outlined">search</span> Lọc</button>
        </form>
    </div>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="admin-table">
            <thead><tr><th>Ảnh</th><th>Tên sản phẩm</th><th>Danh mục</th><th>Giá</th><th>Trạng thái</th><th class="text-right">Thao tác</th></tr></thead>
            <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td>@if (!string.IsNullOrEmpty(p.ImagePath)){<img src="@(p.ImagePath.StartsWith("/") ? p.ImagePath : "/" + p.ImagePath)" class="thumb" alt="" />}</td>
                    <td class="fw-500">@p.Name</td>
                    <td class="text-muted">@(p.Category?.Name ?? "—")</td>
                    <td>
                        @if (p.HasVariants && p.Variants.Any())
                        { <span class="text-sm">@(p.Variants.Min(v => v.Price).ToString("N0"))đ — @(p.Variants.Max(v => v.Price).ToString("N0"))đ</span> }
                        else if (p.SinglePrice.HasValue)
                        { <span>@p.SinglePrice.Value.ToString("N0")đ</span> }
                    </td>
                    <td>@(p.IsActive ? Html.Raw("<span class='badge badge-success'>Đang bán</span>") : Html.Raw("<span class='badge badge-warning'>Ẩn</span>"))</td>
                    <td class="actions">
                        <a href="/admin/products/edit/@p.Id" class="btn btn-sm btn-secondary"><span class="material-symbols-outlined">edit</span></a>
                        <form id="del-prod-@p.Id" method="post" asp-action="Delete" asp-route-id="@p.Id" style="display:inline"></form>
                        <button class="btn btn-sm btn-danger" onclick="confirmDelete('del-prod-@p.Id','@p.Name')"><span class="material-symbols-outlined">delete</span></button>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr><td colspan="6"><div class="empty-state"><span class="material-symbols-outlined">inventory_2</span><p>Chưa có sản phẩm nào</p></div></td></tr>
            }
            </tbody>
        </table>
    </div>
</div>

@if (ViewBag.TotalPages > 1)
{
    <ul class="pagination">
        @for (int i = 1; i <= ViewBag.TotalPages; i++)
        {
            <li class="@(ViewBag.Page == i ? "active" : "")">
                <a href="?categoryId=@ViewBag.SelectedCategory&q=@ViewBag.Search&page=@i">@i</a>
            </li>
        }
    </ul>
}
