@model List<Category>
@{ ViewData["Title"] = "Quản lý Danh mục"; }

<div class="page-header">
    <h2>Danh mục sản phẩm</h2>
    <a href="/admin/categories/create" class="btn btn-primary"><span class="material-symbols-outlined">add</span> Thêm danh mục</a>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="admin-table">
            <thead><tr><th>Tên</th><th>Slug</th><th>Số SP</th><th>Thứ tự</th><th>Trạng thái</th><th class="text-right">Thao tác</th></tr></thead>
            <tbody>
            @foreach (var c in Model)
            {
                <tr>
                    <td class="fw-600">@c.Name</td>
                    <td class="text-muted text-sm">@c.Slug</td>
                    <td>@c.Products.Count</td>
                    <td>@c.SortOrder</td>
                    <td>@(c.IsActive ? Html.Raw("<span class='badge badge-success'>Hiện</span>") : Html.Raw("<span class='badge badge-warning'>Ẩn</span>"))</td>
                    <td class="actions">
                        <a href="/admin/categories/edit/@c.Id" class="btn btn-sm btn-secondary"><span class="material-symbols-outlined">edit</span></a>
                        <form id="del-cat-@c.Id" method="post" asp-action="Delete" asp-route-id="@c.Id" style="display:inline"></form>
                        <button class="btn btn-sm btn-danger" onclick="confirmDelete('del-cat-@c.Id','@c.Name')"><span class="material-symbols-outlined">delete</span></button>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr><td colspan="6"><div class="empty-state"><span class="material-symbols-outlined">category</span><p>Chưa có danh mục nào</p></div></td></tr>
            }
            </tbody>
        </table>
    </div>
</div>
